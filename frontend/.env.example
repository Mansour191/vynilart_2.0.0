# .env.example - Vite Environment Variables for DRF Auth Kit

# DRF Auth Kit Configuration (REQUIRED)
VITE_API_URL=http://127.0.0.1:8000/api
VITE_GRAPHQL_URL=http://127.0.0.1:8000/graphql

# التطبيق العام
VITE_APP_TITLE=فينيل آرت
VITE_APP_URL=https://vinylart.com
VITE_APP_DESCRIPTION="متجر الفينيل الأول في الجزائر"
VITE_APP_BASE_URL=http://localhost:8080

# ERPNext Integration
VITE_ERPNEXT_URL=https://your-erpnext.com
VITE_ERPNEXT_API_KEY=your_api_key_here
VITE_ERPNEXT_API_SECRET=your_api_secret_here
VITE_ERPNEXT_TIMEOUT=30000

# EmailJS - لنظام الإشعارات والبريد
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_USER_ID=your_user_id

# Firebase (اختياري، في حال تفعيله مستقبلاً)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# إعدادات الأمان
VITE_CSRF_SECRET=your_random_secret_here
VITE_DATA_ENCRYPTION_KEY=your_encryption_key_here
